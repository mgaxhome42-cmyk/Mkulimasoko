<!DOCTYPE html>
<html lang="sw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soko la Mazao Tanzania</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen pb-20">

    <div class="fixed top-0 left-0 right-0 h-[4px] flex z-50">
        <div class="flex-1 bg-emerald-600"></div>
        <div class="flex-1 bg-yellow-400"></div>
        <div class="flex-1 bg-blue-600"></div>
        <div class="flex-1 bg-black"></div>
    </div>

    <div class="container mx-auto p-4 max-w-md pt-6">
        <div class="text-center my-6">
            <h1 class="text-3xl font-black tracking-tight bg-gradient-to-r from-emerald-700 via-yellow-600 to-blue-700 bg-clip-text text-transparent">Soko la Mazao</h1>
            <p class="text-sm text-gray-500 mt-1">Ungana na Wakulima na Wasafirishaji Live</p>
        </div>

        <div id="app-body" class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 min-h-[60vh]">
            <div class="space-y-4 text-center pt-8">
                <i class="fa-solid fa-wheat-awn text-5xl text-emerald-600 animate-bounce"></i>
                <h2 class="text-xl font-bold">Karibu Sokoni</h2>
                <p class="text-sm text-gray-500">Chagua jukumu lako hapa chini kuanza biashara.</p>
            </div>
        </div>
    </div>

    <nav class="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-md border-t border-gray-200 py-2 px-6 flex justify-around shadow-lg z-40">
        <button onclick="changePage('customer')" class="flex flex-col items-center space-y-1 text-amber-500 font-medium">
            <i class="fa-solid fa-basket-shopping text-xl"></i>
            <span class="text-xs">Mteja</span>
        </button>
        <button onclick="changePage('farmer')" class="flex flex-col items-center space-y-1 text-emerald-600 font-medium">
            <i class="fa-solid fa-seedling text-xl"></i>
            <span class="text-xs">Mkulima</span>
        </button>
        <button onclick="changePage('transporter')" class="flex flex-col items-center space-y-1 text-blue-600 font-medium">
            <i class="fa-solid fa-truck text-xl"></i>
            <span class="text-xs">Msafirishaji</span>
        // WEKA FUNGUO ZAKO NDANI YA ALAMA ZA NUKUU "" HAPA CHINI
const SUPABASE_URL = "https://wlmcdkveocbsumjehtnq.supabase.co";
const SUPABASE_KEY = "sb_publishable_lfhyHQtJAT7jt8TBJv3wDQ_7FZHgYy3"; 
const supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

async function changePage(role) {
    const body = document.getElementById('app-body');
            
            if(role === 'customer') {
                body.innerHTML = `
                    <h3 class="text-lg font-bold text-amber-600 mb-4"><i class="fa-solid fa-basket-shopping"></i> Mazao Yanayouzwa Live</h3>
                    <div id="loading" class="text-center text-xs py-4 text-gray-400">Inavuta mazao yaliyopo sokoni...</div>
                    <div id="mazao-list" class="space-y-3"></div>`;
                
                const { data, error } = await supabaseClient.from('mazao').select('*').order('created_at', { ascending: false });
                
                document.getElementById('loading').style.display = 'none';
                const listDiv = document.getElementById('mazao-list');
                
                if (data && data.length > 0) {
                    data.forEach(zao => {
                        listDiv.innerHTML += `
                            <div class="border rounded-xl p-3 bg-gray-50 flex gap-3 shadow-sm border-gray-100">
                                <div class="w-12 h-12 bg-emerald-100 rounded-lg flex items-center justify-center text-xl">🌾</div>
                                <div>
                                    <h4 class="font-bold text-gray-900">${zao.aina_ya_zao}</h4>
                                    <p class="text-xs text-gray-500">Mkoa: ${zao.eneo}</p>
                                    <p class="text-sm font-bold text-emerald-600">TSH ${Number(zao.bei).toLocaleString()} / Kg</p>
                                </div>
                            </div>`;
                    });
                } else {
                    listDiv.innerHTML = `<p class="text-center text-xs text-gray-400 py-6">Hakuna zao lililowekwa sokoni kwa sasa.</p>`;
                }
                
            } else if(role === 'farmer') {
                body.innerHTML = `
                    <h3 class="text-lg font-bold text-emerald-600 mb-3"><i class="fa-solid fa-seedling"></i> Jopo la Mkulima</h3>
                    <form class="space-y-3" id="zaoForm">
                        <div><label class="text-xs font-bold">Aina ya Zao</label><input type="text" id="aina" class="w-full border rounded-lg p-2 text-sm" placeholder="Mf. Nyanya, Mpunga, Vitunguu" required></div>
                        <div><label class="text-xs font-bold">Bei ya Kuuzia (kwa Kg)</label><input type="number" id="bei" class="w-full border rounded-lg p-2 text-sm" placeholder="TSH" required></div>
                        <div><label class="text-xs font-bold">Eneo / Mkoa uliopo</label><input type="text" id="eneo" class="w-full border rounded-lg p-2 text-sm" placeholder="Mf. Iringa, Morogoro" required></div>
                        <button type="submit" id="submitBtn" class="w-full bg-emerald-600 text-white rounded-lg py-2 font-bold text-sm shadow-md mt-2">+ Tuma Sokoni Live</button>
                    </form>`;

                document.getElementById('zaoForm').addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const btn = document.getElementById('submitBtn');
                    btn.innerText = "Inatuma sokoni...";
                    btn.disabled = true;

                    const aina_ya_zao = document.getElementById('aina').value;
                    const bei = document.getElementById('bei').value;
                    const eneo = document.getElementById('eneo').value;

                    const { error } = await supabaseClient.from('mazao').insert([{ aina_ya_zao, bei, eneo }]);

                    if(!error) {
                        alert('Hongera! Zao lako limeingia sokoni live!');
                        changePage('farmer');
                    } else {
                        alert('Imeshindikana: ' + error.message);
                        btn.innerText = "+ Tuma Sokoni Live";
                        btn.disabled = false;
                    }
                });
            } else if(role === 'transporter') {
                body.innerHTML = `
                    <h3 class="text-lg font-bold text-blue-600 mb-4"><i class="fa-solid fa-truck"></i> Wasafirishaji</h3>
                    <p class="text-xs text-gray-500">Sehemu ya kuomba usafiri inakuja hivi punde kwenye toleo lijalo...</p>`;
            }
        }
    </script>
</body>
</html>
